[user]
name = Dennis Bakhuis
email = git@bakhuis.nu
[pull]
	rebase = false

[push]
	autoSetupRemote = true

[color]
	ui = auto
	status = auto
	branch = auto
	diff = auto
	interactive = auto

# Azure DevOps URL rewriting for tennetidc organization
# Rewrites git@ssh.dev.azure.com:v3/tennetidc -> git@tennet-idc:v3/tennetidc
[url "git@tennet-idc:v3/tennetidc"]
	insteadOf = git@ssh.dev.azure.com:v3/tennetidc

# Azure DevOps URL rewriting for MCP-TenneT organization
# Rewrites git@ssh.dev.azure.com:v3/MCP-TenneT -> git@tennet-mcp:v3/MCP-TenneT
[url "git@tennet-mcp:v3/MCP-TenneT/"]
	insteadOf = git@ssh.dev.azure.com:v3/MCP-TenneT/
[include]
	path = ~/.gitconfig.local
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
