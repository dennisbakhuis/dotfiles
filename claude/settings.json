{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(command -v:*)",
      "Bash(lsof:*)",
      "Bash(ps:*)",
      "Bash(kill:*)",
      "Bash(git:*)",
      "Bash(gh auth *)",
      "Bash(gh pr *)",
      "Bash(fj --help)",
      "Bash(fj pr *)",
      "Bash(uv:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(tofu version *)",
      "Bash(tofu fmt *)",
      "Bash(tofu init *)",
      "Bash(tofu validate *)",
      "Bash(brew list:*)",
      "Bash(cwebp:*)",
      "Bash(avifenc:*)",
      "Bash(fastfetch --version)",
      "Bash(tmux -V)",
      "Bash(tmux show-options *)",
      "Bash(fish:*)",
      "Bash(~/.local/bin/pass-cli run *)",
      "Bash(~/.local/bin/pass-cli inject *)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.terraform.io)",
      "WebFetch(domain:docs.hetzner.com)",
      "WebFetch(domain:letsencrypt.org)",
      "WebFetch(domain:go-acme.github.io)",
      "WebFetch(domain:protonpass.github.io)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fx*)",
      "Read(//Users/*/.ssh/**)",
      "Read(//home/*/.ssh/**)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f ~/.claude-chime ] && afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/dotfiles/claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "teammateMode": "tmux",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
